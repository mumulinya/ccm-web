{
  "name": "ccm",
  "private": true,
  "version": "1.0.0",
  "description": "CCM development workspace",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "node ccm-package/dist/server.js",
    "check": "tsc -p backend/tsconfig.json --noEmit && tsc -p integrations/mcp-feishu/tsconfig.json --noEmit",
    "check:split-exports": "npm run build:backend && node scripts/check-split-exports.js && node scripts/check-factory-deps.js",
    "check:split": "npm run check && npm run check:split-exports",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "npm --prefix frontend run build",
    "build:mcp-feishu": "tsc -p integrations/mcp-feishu/tsconfig.json",
    "build": "npm run build:frontend && npm run build:mcp-feishu && npm run build:backend",
    "docs:catalog": "node scripts/generate-doc-catalogs.mjs && node scripts/generate-main-agent-doc-catalog.mjs",
    "docs:check": "npm run docs:catalog && node scripts/check-doc-links.mjs",
    "storage:status": "npm run build:backend && node scripts/task-store-sqlite.mjs status",
    "storage:verify": "npm run build:backend && node scripts/task-store-sqlite.mjs verify",
    "storage:backup": "npm run build:backend && node scripts/task-store-sqlite.mjs backup",
    "storage:export": "npm run build:backend && node scripts/task-store-sqlite.mjs export",
    "release:normalize-tarball-modes": "node scripts/normalize-npm-tarball-modes.mjs",
    "release:preflight": "npm run build && node scripts/release-live-acceptance.mjs",
    "release:acceptance:live": "npm run build && node scripts/release-live-acceptance.mjs --live --require-all --live-feishu",
    "release:package-install": "npm run build && node scripts/npm-package-install-release-selftest.mjs",
    "stability:9:start": "node scripts/start-clean-soak-9.js",
    "stability:9:check": "node scripts/check-clean-soak-9.js",
    "pack": "npm pack ./ccm-package",
    "test": "npm run test:quick",
    "test:quick": "node scripts/domain-test-runner.mjs quick",
    "test:all": "node scripts/domain-test-runner.mjs all",
    "test:domain": "node scripts/domain-test-runner.mjs",
    "test:core": "node scripts/domain-test-runner.mjs core",
    "test:memory": "node scripts/domain-test-runner.mjs memory",
    "test:tasks": "node scripts/domain-test-runner.mjs tasks",
    "test:agents": "node scripts/domain-test-runner.mjs agents",
    "test:integrations": "node scripts/domain-test-runner.mjs integrations",
    "test:frontend": "node scripts/domain-test-runner.mjs frontend",
    "test:knowledge": "node scripts/domain-test-runner.mjs knowledge",
    "test:media": "node scripts/domain-test-runner.mjs media",
    "test:release": "node scripts/domain-test-runner.mjs release",
    "test:legacy": "node scripts/domain-test-runner.mjs legacy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.61.1",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "node-pty": "1.2.0-beta.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "name": "ccm",
  "private": true,
  "version": "1.0.0",
  "description": "CCM development workspace",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "node ccm-package/dist/server.js",
    "check": "tsc -p backend/tsconfig.json --noEmit && tsc -p integrations/mcp-feishu/tsconfig.json --noEmit",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "npm --prefix frontend run build",
    "build:mcp-feishu": "tsc -p integrations/mcp-feishu/tsconfig.json",
    "build": "npm run build:frontend && npm run build:mcp-feishu && npm run build:backend",
    "test:render-regression": "node scripts/main-agent-render-regression.mjs",
    "test:replay-regression": "node scripts/main-agent-replay-regression.mjs",
    "test:coordinator": "npm run build:backend && node ccm-package/scripts/coordinator-smoke.js",
    "test:chat-experience": "node scripts/unified-chat-task-experience-selftest.mjs && node scripts/unified-chat-task-experience-e2e.mjs",
    "test:code-changes": "node scripts/agent-code-change-visualization-selftest.mjs",
    "test:project-agent-soak": "node scripts/project-agent-real-soak.mjs",
    "stability:9:start": "node scripts/start-clean-soak-9.js",
    "stability:9:check": "node scripts/check-clean-soak-9.js",
    "pack": "npm pack ./ccm-package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

        <div class="footer-right">
          <span class="footer-metric">PACKET_LOSS: {{ packetLoss.toFixed(2) }}%</span>
          <span class="footer-divider">|</span>
          <span class="footer-metric">SYNC_STATUS: VERIFIED</span>
          <span class="footer-divider">|</span>
          <span class="footer-metric">NODE_VERSION: 1.0.4-BETA</span>
        </div>
      </footer>

    </div>

    <!-- Agent 配置弹窗 -->
    <div v-if="showSettings" class="settings-overlay" @click.self="showSettings = false">
      <div class="settings-modal">
        <div class="settings-header">
          <span>⚙️ Agent 配置</span>
          <button class="close-btn" @click="showSettings = false">&times;</button>
        </div>
        <div class="settings-body">
          <div class="field">
            <label>API URL</label>
            <input v-model="agentConfig.apiUrl" placeholder="https://api.anthropic.com" />
            <span class="hint">Anthropic API 或兼容接口地址</span>
          </div>
          <div class="field">
            <label>API Key</label>
            <input v-model="agentConfig.apiKey" type="password" placeholder="sk-ant-..." />
            <span class="hint">Anthropic API Key（配置后启用 Claude Agent 模式）</span>
          </div>
          <div class="field">
            <label>模型</label>
            <input v-model="agentConfig.model" placeholder="claude-sonnet-4-20250514" />
            <span class="hint">推荐: claude-sonnet-4-20250514</span>
          </div>
          <div class="field">
            <label>API 格式</label>
            <select v-model="agentConfig.format" class="config-select">
              <option value="auto">自动检测</option>
              <option value="openai">OpenAI 兼容（DeepSeek/中转站）</option>
              <option value="anthropic">Anthropic 原生</option>
            </select>
          </div>
          <div class="field">
            <label>HTTP 代理（可选）</label>
            <input v-model="agentConfig.proxy" placeholder="http://127.0.0.1:7890" />
            <span class="hint">B站搜索被封时配置代理，支持 http/socks5</span>
          </div>
        </div>
        <div class="settings-footer">
          <button class="btn-aura" @click="showSettings = false">取消</button>
          <button class="btn-aura btn-primary" @click="saveAgentConfig">保存</button>
        </div>
      </div>
    </div>
  </div>
</template>

